class Solution:
    def minPairSum(self, nums: list[int]) -> int:
        nums.sort()
        max_sum = 0
        left = 0
        right = len(nums) - 1
        
        while left < right:
            current_pair_sum = nums[left] + nums[right]
            if current_pair_sum > max_sum:
                max_sum = current_pair_sum
                
            left += 1
            right -= 1
            
        return max_sum
